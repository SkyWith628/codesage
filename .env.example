# ===== CodeSage 환경변수 예시 =====
# 사용법: cp .env.example .env  후 값을 채우세요.
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 포함됨).

# --- Gemini API (Google) ---
# 없으면 llm_reviewer가 'mock 리뷰'를 반환합니다(키 없이도 파이프라인 시연 가능).
# 키 발급: https://aistudio.google.com/apikey  (무료)
GEMINI_API_KEY=

# 리뷰용/요약용 모델 (무료 티어: gemini-2.0-flash)
REVIEW_MODEL=gemini-2.0-flash
SUMMARY_MODEL=gemini-2.0-flash

# --- GitHub Webhook ---
# Webhook 서명 검증용 시크릿. 임의의 긴 랜덤 문자열을 생성해 넣으세요.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- GitHub 인증 (운영 모드에서만 필요. 로컬 시연만 할 거면 비워둬도 됨) ---
GITHUB_API_BASE=https://api.github.com

# 방식 A) GitHub App (권장): 설치된 레포마다 1시간짜리 토큰을 자동 발급.
#   App 설정 → "Generate a private key"로 받은 .pem 파일 경로 또는 본문을 넣으세요.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=          # 예: secrets/codesage.private-key.pem
# 또는 파일 대신 본문을 한 줄로(줄바꿈은 \n) 넣을 수도 있습니다:
GITHUB_APP_PRIVATE_KEY=

# 방식 B) PAT 폴백: App을 안 쓰면 개인 액세스 토큰을 사용 (App 설정이 있으면 무시됨).
GITHUB_TOKEN=

# 대화형 후속을 부르는 멘션. 코멘트에 이 문자열이 있으면 봇이 답변합니다.
BOT_MENTION=@codesage

# --- Redis (작업 큐) ---
REDIS_URL=redis://localhost:6379/0
QUEUE_KEY=codesage:review:queue

# --- PostgreSQL (리뷰 기록 영속화. 비워두면 DB 저장을 건너뜀) ---
# docker compose 사용 시: postgresql+asyncpg://codesage:codesage@postgres:5432/codesage
DATABASE_URL=

# --- 설정 파일 경로 ---
CONFIG_PATH=config/codesage.yaml
